# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.npm-cache
**/.npm-cache/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local content archive (assets live in Sanity, not in the repo)
/Image Backup/

# sanity typegen intermediate artifact (regenerate with `npm run typegen`;
# the generated src/sanity/sanity.types.ts IS committed)
/src/sanity/schema.json

# agent tooling (skills are machine-installed; keep only .claude/launch.json tracked)
/.agents/
/.claude/skills/
/.claude/settings.local.json
/skills-lock.json
